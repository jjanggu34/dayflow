{
  "version": 2,
  "name": "dayflow",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    {
      "src": "/api/open-meteo/(.*)",
      "dest": "https://api.open-meteo.com/$1"
    },
    { "src": "/", "dest": "/index.html" },
    { "src": "/login", "dest": "/views/login.html" },
    { "src": "/home", "dest": "/views/home/home.html" },
    { "src": "/chat/emotion", "dest": "/views/chat/emotion.html" },
    { "src": "/chat/result", "dest": "/views/chat/result.html" },
    { "src": "/chat", "dest": "/views/chat/chat.html" },
    { "src": "/report/report", "dest": "/views/report/report.html" },
    { "src": "/report", "dest": "/views/report/report.html" },
    { "src": "/advice/advice", "dest": "/views/advice/advice.html" },
    { "src": "/advice", "dest": "/views/advice/advice.html" },
    { "src": "/my", "dest": "/views/my/my.html" }
  ]
}
